# .env.example — Remodelaciones master template
# Copy this file to `.env` and complete values per client deployment.
# Never commit `.env` files with real credentials.

# [OPTIONAL] App public URL (frontend consumption).
VITE_APP_URL=https://your-client-domain.com

# [REQUIRED for admin access] Email allowed for admin panel features.
VITE_ADMIN_EMAIL=admin@yourdomain.com

# [OPTIONAL] Lead webhook endpoint for CRM/Zapier/Make automation.
# Leave empty to keep contact form in local-only mode.
VITE_LEAD_WEBHOOK_URL=

# [OPTIONAL] Analytics ID (GA4, Plausible, etc. depending on implementation).
VITE_ANALYTICS_ID=

# [SERVER-ONLY / OPTIONAL] If you later add backend AI routes.
GEMINI_API_KEY=

# [SERVER-ONLY / OPTIONAL] If you use Cursor MCP integrations.
TWENTY_FIRST_DEV_MAGIC_API_KEY=

# Firebase credentials are NOT stored in this .env.
# Replace `firebase-applet-config.json` in the project root for each new client:
# Firebase Console -> Project Settings -> Your apps -> SDK setup and configuration.
